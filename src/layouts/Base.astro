---
import MegaNav from '../components/MegaNav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const {
  title,
  description = 'Partner #1 de Odoo a nivel mundial. Implementamos Odoo para que tu empresa pueda escalar sin sumar complejidad.',
  currentPage = '',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description}>
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/logos/isotipo.svg">
  </head>
  <body>
    <MegaNav currentPage={currentPage} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
