.roi-slider-lbl { font-family:var(--font-body);font-size:.875rem;color:var(--color-text-secondary);margin-bottom:var(--space-sm);display:flex;align-items:baseline;gap:6px; }
.roi-slider-num { font-weight:500;font-size:1.25rem;color:var(--color-primary); }
.roi-slider { appearance:none;-webkit-appearance:none;width:100%;height:4px;background:var(--border-medium);border-radius:999px;outline:none; }
.roi-slider::-webkit-slider-thumb { appearance:none;-webkit-appearance:none;width:18px;height:18px;border-radius:50%;background:var(--color-surface);border:2px solid var(--color-primary);cursor:pointer; }
.roi-slider::-moz-range-thumb { width:18px;height:18px;border-radius:50%;background:var(--color-surface);border:2px solid var(--color-primary);cursor:pointer; }
.roi-slider-axis { display:flex;justify-content:space-between;font-family:var(--font-body);font-size:.6875rem;color:var(--color-text-secondary);margin-top:var(--space-xs); }
.roi-detected { margin-top:var(--space-sm);display:flex;align-items:center;gap:var(--space-xs); }
.roi-detected-lbl { font-family:var(--font-body);font-size:.75rem;color:var(--color-text-secondary); }
.roi-pill { font-family:var(--font-body);font-size:.75rem;font-weight:500;padding:4px 10px;border-radius:999px;background:var(--color-lavender-fill);color:var(--color-lavender); }
.roi-mcard { background:var(--color-canvas);border-radius:var(--radius-input);padding:var(--space-sm) var(--space-md);display:flex;justify-content:space-between;align-items:center; }
.roi-mcard-lbl { font-family:var(--font-body);font-size:.8125rem;color:var(--color-text-secondary); }
.roi-mcard-val { font-family:var(--font-body);font-size:1.375rem;font-weight:500;color:var(--color-primary);transition:opacity .15s; }
.roi-hero-card { background:var(--color-primary);border-radius:var(--radius-button);padding:var(--space-lg);color:#fff;display:flex;flex-direction:column;gap:var(--space-xs); }
.roi-hero-pill { align-self:flex-start;border:1px solid rgba(255,255,255,.3);background:rgba(255,255,255,.15);color:#fff;font-family:var(--font-body);font-size:.75rem;font-weight:500;padding:4px 10px;border-radius:999px; }
.roi-hero-price { font-family:var(--font-body);font-size:1.875rem;font-weight:500;color:#fff;line-height:1.1; }
.roi-hero-impl  { font-family:var(--font-body);font-size:.8125rem;color:var(--color-lavender); }
.roi-hero-desc  { font-family:var(--font-body);font-size:.8125rem;color:rgba(255,255,255,.78);line-height:1.45; }
.roi-hero-cta   { margin-top:var(--space-xs);display:flex;align-items:center;justify-content:center;background:var(--color-surface);color:var(--color-primary);font-family:var(--font-body);font-weight:500;font-size:.875rem;padding:11px;border-radius:var(--radius-button);border:none;cursor:pointer;transition:background .15s; }
.roi-hero-cta:hover { background:var(--color-canvas); }

/* ─── 4. Rubros ─── */
.rubros-outer { max-width:1200px;margin:0 auto;padding:0 var(--space-xl);display:grid;grid-template-columns:30% 70%;gap:var(--space-3xl);align-items:start; }
.rubros-left { position:sticky;top:80px;display:flex;flex-direction:column;gap:var(--space-lg); }
.rubros-hed { font-family:var(--font-display);font-weight:500;font-size:1.375rem;line-height:1.25; }
.rubros-chips { display:flex;flex-direction:column;gap:var(--space-md);margin-top:4px; }
.rchip { display:block;font-family:var(--font-display);font-size:1.875rem;font-weight:500;color:var(--color-ink);background:none;border:none;padding:0;cursor:pointer;text-align:left;opacity:.6;line-height:1.2;transition:opacity .2s; }
.rchip:hover { opacity:.8; }
.rchip--active { opacity:1; }
.rubros-right { display:flex;flex-direction:column;gap:var(--space-4xl); }
.rblock { display:flex;flex-direction:column;gap:var(--space-md); }
.rblock :global(.tag) { align-self:flex-start; }
.rblock-title { font-family:var(--font-display);font-weight:500;font-size:1.75rem;line-height:1.2;max-width:560px; }
.rblock-sub { font-family:var(--font-body);font-size:1rem;color:var(--color-text-secondary);line-height:1.6;max-width:520px; }
.rblock-img { width:100%;height:280px;border-radius:clamp(16px,5vw,32px);background:var(--card-bg);border:1px solid var(--border-subtle);display:flex;align-items:center;justify-content:center;font-family:var(--font-body);font-size:.875rem;font-weight:500;color:var(--color-text-secondary);margin-top:var(--space-xs); }

/* ─── 5. Feature Tabs ─── */
.ft-dots { display:flex;justify-content:center;gap:var(--space-xs);margin-top:var(--space-lg); }
.ft-dot-btn { width:7px;height:7px;border-radius:999px;background:var(--border-medium);border:none;cursor:pointer;padding:0;transition:background .2s,width .2s; }
.ft-dot-btn.ft-dot-active { background:var(--color-ink);width:24px; }
.ft-headline { font-family:var(--font-display);font-weight:500;font-size:clamp(2.2rem,3.8vw,3.2rem);line-height:1.08;letter-spacing:-.025em;text-align:center;max-width:760px;margin:0 auto var(--space-2xl); }
.ft-headline em { font-style:italic;color:var(--color-primary); }
.ft-tabs { display:flex;flex-wrap:wrap;justify-content:center;gap:var(--space-xs);margin-bottom:var(--space-xl); }
.ft-tab { font-family:var(--font-body);font-size:.9375rem;font-weight:500;padding:11px 22px;border-radius:999px;border:none;cursor:pointer;background:rgba(255,255,255,0.12);color:#fff;transition:background .2s,color .2s;white-space:nowrap; }
.ft-tab:hover { background:rgba(255,255,255,0.2); }
.ft-tab--active { background:var(--color-mustard);color:var(--color-ink); }
.ft-tab--active:hover { background:var(--color-mustard);opacity:.75; }
.ft-panel { display:none;border-radius:clamp(20px,4vw,40px);padding:var(--space-3xl);min-height:480px;align-items:center;background:var(--ft-bg,var(--color-surface));color:var(--ft-ink,var(--color-ink)); }
.ft-panel--active { display:grid;grid-template-columns:1fr 1fr;gap:var(--space-3xl); }
.ft-visual { display:flex;align-items:center;justify-content:center;min-height:320px; }
.ft-text { display:flex;flex-direction:column;gap:var(--space-md); }
.ft-eyebrow { font-family:var(--font-body);font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;opacity:.6; }
.ft-title { font-family:var(--font-display);font-weight:500;font-size:clamp(1.8rem,2.8vw,2.4rem);line-height:1.1;letter-spacing:-.02em; }
.ft-sub { font-family:var(--font-body);font-size:1.0625rem;line-height:1.6;opacity:.85;max-width:380px; }
.ft-cta { align-self:flex-start;font-family:var(--font-body);font-size:.9375rem;font-weight:500;padding:12px 24px;border-radius:var(--radius-button);cursor:pointer;background:transparent;margin-top:var(--space-xs);border:1.5px solid currentColor;transition:background .18s,color .18s; }
.ft-cta:hover { background:var(--ft-ink,var(--color-ink));color:var(--ft-bg,var(--color-surface)); }
/* Mocks */
.ft-mock { background:var(--color-surface);border-radius:var(--radius-button);padding:var(--space-sm);color:var(--color-ink);width:100%;max-width:520px;border:1px solid var(--border-subtle); }
.ft-mock-bar { display:flex;align-items:center;gap:5px;padding-bottom:var(--space-xs);border-bottom:1px solid var(--border-subtle);margin-bottom:var(--space-sm); }
.ft-mock-dot { width:9px;height:9px;border-radius:50%;flex-shrink:0;display:block; }
.ft-mock-title { font-family:var(--font-display);font-weight:500;font-size:.85rem;margin-left:6px; }
.ft-pipe { display:grid;grid-template-columns:repeat(4,1fr);gap:var(--space-xs); }
.ft-pipe-col { background:var(--color-canvas);border-radius:var(--radius-tag);padding:var(--space-xs); }
.ft-pipe-lbl { font-family:var(--font-body);font-size:.58rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:#888;margin-bottom:6px; }
.ft-pc { background:var(--color-surface);border-radius:6px;padding:var(--space-xs);font-size:.65rem;border:1px solid var(--border-subtle); }
.ft-pc-id { color:#888;font-size:.55rem;margin-bottom:2px; }
.ft-pc-nm { font-weight:600; }
.ft-pc-mt { font-size:.55rem;color:#888;margin-top:4px;display:flex;justify-content:space-between; }
.ft-pc--done { background:#E8F5EE;border-color:#B8E2C8; }
.ft-pc--auto { background:var(--color-lavender-fill);border-color:var(--color-lavender); }
/* Hub */
.ft-hub-wrap { position:relative;width:320px;height:280px;display:flex;align-items:center;justify-content:center; }
.ft-hub-center { background:var(--color-surface);border:1px solid var(--border-subtle);border-radius:var(--radius-button);padding:var(--space-xs) var(--space-sm);font-family:var(--font-body);font-size:.75rem;font-weight:600;color:var(--color-ink);z-index:1; }
.ft-hub-nodes { position:absolute;inset:0; }
.ft-hub-node { position:absolute;background:var(--color-surface);border:1px solid var(--border-subtle);border-radius:var(--radius-button);padding:6px 10px;font-family:var(--font-body);font-size:.72rem;font-weight:500;color:var(--color-ink);white-space:nowrap;transform:translate(-50%,-50%); }
/* Tree */
.ft-tree-root { background:var(--color-ink);color:var(--color-canvas);border-radius:var(--radius-button);padding:var(--space-xs) var(--space-md);font-family:var(--font-display);font-weight:500;font-size:.85rem;display:inline-block; }
.ft-tree-row { display:flex;gap:var(--space-xs);flex-wrap:wrap;justify-content:center;margin-top:var(--space-xs); }
.ft-tree-node { background:var(--color-surface);border:1px solid var(--border-subtle);border-radius:var(--radius-input);padding:6px 10px;font-family:var(--font-body);font-size:.72rem;font-weight:600; }
.ft-tree-note { font-family:var(--font-body);font-size:.65rem;color:rgba(0,0,0,.4);display:flex;align-items:center;justify-content:center;margin-top:var(--space-xs); }
/* KPIs */
.ft-kpi-row { display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-xs);margin-bottom:var(--space-xs); }
.ft-kpi { background:var(--color-canvas);border-radius:var(--radius-tag);padding:var(--space-xs); }
.ft-kpi-l { font-family:var(--font-body);font-size:.58rem;color:#888;margin-bottom:3px; }
.ft-kpi-v { font-family:var(--font-display);font-weight:600;font-size:1.1rem;line-height:1; }
.ft-kpi-d { font-family:var(--font-body);font-size:.58rem;font-weight:600;margin-top:3px; }
.ft-kpi-d--up { color:#3BB56A; }
.ft-kpi-d--dn { color:var(--color-coral); }
.ft-chart-row { display:flex;align-items:flex-end;gap:4px;height:64px; }
.ft-bar-wrap { flex:1;background:var(--color-lavender);border-radius:3px 3px 0 0; }
.ft-bar-wrap--hi { background:var(--color-primary); }
/* Finance table */
.ft-fin-tag { font-family:var(--font-body);font-size:.55rem;font-weight:700;background:var(--color-ink);color:#fff;padding:3px 8px;border-radius:999px;letter-spacing:.04em;margin-left:auto; }
.ft-fin-row { display:grid;grid-template-columns:1.5fr .9fr .9fr .6fr;gap:var(--space-sm);padding:9px var(--space-sm);border-bottom:1px solid var(--border-subtle);font-family:var(--font-body);font-size:.75rem;align-items:center; }
.ft-fin-row--head { font-size:.58rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#888;background:var(--color-canvas); }
.ft-fin-row--tot { background:var(--color-canvas);font-weight:700; }
.ft-pos { color:#3BB56A; }
.ft-neg { color:var(--color-coral); }
/* Digi */
.ft-digi { display:flex;align-items:center;gap:var(--space-md);width:100%;max-width:520px; }
.ft-paper { background:var(--color-surface);border-radius:var(--radius-input);padding:var(--space-sm);border:1px solid var(--border-subtle);flex:1;transform:rotate(-3deg);position:relative; }
.ft-paper-title { font-family:var(--font-display);font-weight:500;font-size:.82rem;margin-bottom:var(--space-xs);color:var(--color-ink); }
.ft-paper-line { height:4px;background:var(--border-subtle);border-radius:3px;margin-bottom:5px; }
.ft-paper-line--70 { width:70%; }
.ft-paper-line--90 { width:90%; }
.ft-paper-line--60 { width:60%; }
.ft-paper-warn { font-family:var(--font-body);font-size:.58rem;color:var(--color-coral);font-weight:700;margin-top:var(--space-xs); }
.ft-digi-arrow { font-size:1.4rem;color:rgba(0,0,0,.3);flex-shrink:0; }
.ft-app-card { background:var(--color-surface);border-radius:var(--radius-input);padding:var(--space-sm);border:1px solid var(--border-subtle);flex:1; }
.ft-app-title { font-family:var(--font-body);font-size:.75rem;font-weight:600;color:var(--color-ink);padding-bottom:var(--space-xs);border-bottom:1px solid var(--border-subtle);margin-bottom:var(--space-xs); }
.ft-app-row { display:flex;align-items:center;justify-content:space-between;padding:7px 0;font-family:var(--font-body);font-size:.7rem;color:var(--color-ink);border-bottom:1px solid var(--border-subtle); }
.ft-app-row:last-child { border:none; }
.ft-ck { width:13px;height:13px;border-radius:50%;border:1.5px solid var(--border-medium);flex-shrink:0;display:block; }
.ft-ck--done { background:#3BB56A;border-color:#3BB56A; }

/* ─── 6. Métricas ─── */
.metrics-hdr { text-align:center;margin-bottom:var(--space-2xl);display:flex;flex-direction:column;align-items:center; }
.metrics-row { display:grid;grid-template-columns:repeat(4,1fr);border:1px solid var(--border-subtle);border-radius:clamp(16px,5vw,32px);overflow:hidden; }
.metric-cell { background:var(--color-surface);padding:var(--space-2xl) var(--space-xl);display:flex;flex-direction:column;gap:var(--space-xs);border-right:1px solid var(--border-subtle); }
.metric-cell:last-child { border-right:none; }
.metric-arrow { font-size:1.6rem;font-weight:700;line-height:1;color:var(--color-primary); }
.metric-arrow--up { color:var(--color-coral); }
.metric-num { font-family:var(--font-display);font-weight:700;font-size:3.5rem;line-height:1;letter-spacing:-.03em; }
.metric-num--up { color:var(--color-coral); }
.metric-lbl { font-family:var(--font-body);font-size:.875rem;font-weight:500;color:var(--color-text-secondary);line-height:1.4; }
.metrics-cta { text-align:center;margin-top:var(--space-2xl); }

/* ─── 7. Proceso ─── */
.proceso-hdr { text-align:center;margin-bottom:var(--space-3xl);display:flex;flex-direction:column;align-items:center; }
.proceso-hed { font-family:var(--font-display);font-weight:500;font-size:clamp(2.4rem,4.2vw,3.6rem);line-height:1.05;letter-spacing:-.02em;max-width:880px;margin-top:var(--space-md); }
.proceso-hed em { font-style:italic;color:var(--color-primary); }
.proceso-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-lg); }
.pcard { background:#D9D4CD;border:none;border-radius:clamp(16px,5vw,32px);padding:var(--space-2xl) var(--space-xl);display:flex;flex-direction:column;gap:var(--space-md);min-height:520px; }
.pcard-num { font-family:var(--font-display);font-weight:600;font-size:1rem;color:var(--color-primary);text-align:center; }
.pcard-title { font-family:var(--font-display);font-weight:500;font-size:2rem;line-height:1.05;letter-spacing:-.015em;text-align:center; }
.pcard-sub { font-family:var(--font-body);font-size:.9375rem;color:var(--color-text-secondary);text-align:center;line-height:1.45;max-width:280px;margin:0 auto; }
.pcard-vis { margin-top:auto;display:flex;align-items:center;justify-content:center;padding-top:var(--space-lg); }
/* Diag */
.diag-list { display:flex;flex-direction:column;gap:var(--space-xs);width:100%;max-width:300px; }
.diag-item { display:flex;align-items:center;gap:var(--space-xs);background:#F6F6F6;border:1px solid var(--border-subtle);border-radius:var(--radius-button);padding:11px var(--space-sm);font-family:var(--font-body);font-size:.8125rem; }
.diag-dot { width:10px;height:10px;border-radius:50%;flex-shrink:0;display:block; }
.diag-tag { margin-left:auto;font-family:var(--font-body);font-size:.65rem;font-weight:600;letter-spacing:.04em;text-transform:uppercase;padding:3px var(--space-xs);border-radius:999px; }
.diag-tag--red { background:#FFE5DE;color:#C13E2D; }
.diag-tag--yel { background:#FFF1D2;color:#9C6F0E; }
.diag-tag--lav { background:var(--color-lavender-fill);color:var(--color-primary); }
.diag-tag--grn { background:#E1F4E8;color:#1F7A47; }
/* Imp */
.imp-mock { width:100%;max-width:300px;background:#F6F6F6;border:1px solid var(--border-subtle);border-radius:var(--radius-button);padding:var(--space-sm);display:flex;flex-direction:column;gap:6px; }
.imp-row { display:flex;align-items:center;gap:var(--space-xs);padding:9px 11px;border-radius:var(--radius-input);font-family:var(--font-body);font-size:.78rem;background:var(--color-canvas); }
.imp-row--active { background:var(--color-lavender-fill); }
.imp-dot { width:9px;height:9px;border-radius:50%;flex-shrink:0;display:block; }
.imp-state { margin-left:auto;font-family:var(--font-body);font-size:.65rem;font-weight:600;color:#888; }
.imp-state--ok  { color:#3BB56A; }
.imp-state--cur { color:var(--color-primary); }
.imp-progress { margin-top:6px;padding:0 11px; }
.imp-progress-lbl { font-family:var(--font-body);font-size:.65rem;color:var(--color-text-secondary);margin-bottom:4px; }
.imp-progress-bar { background:var(--color-canvas);border-radius:4px;height:6px;overflow:hidden; }
.imp-progress-fill { background:var(--color-primary);height:100%; }
/* Opt */
.opt-vis { width:100%;max-width:300px;background:#F6F6F6;border:1px solid var(--border-subtle);border-radius:var(--radius-button);padding:var(--space-md); }
.opt-lbl { font-family:var(--font-body);font-size:.7rem;font-weight:600;color:var(--color-text-secondary);letter-spacing:.06em;text-transform:uppercase;margin-bottom:var(--space-xs); }
.opt-val { font-family:var(--font-display);font-weight:500;font-size:1.5rem;margin-bottom:var(--space-sm);display:flex;align-items:baseline;gap:var(--space-xs); }
.opt-delta { font-family:var(--font-body);font-size:.75rem;font-weight:600;color:#3BB56A;background:#E1F4E8;padding:2px var(--space-xs);border-radius:999px; }
.opt-chart { display:block; }
.opt-axis { display:flex;justify-content:space-between;margin-top:var(--space-xs);font-family:var(--font-body);font-size:.65rem;color:var(--color-text-secondary); }
.proceso-cta { display:flex;justify-content:center;gap:var(--space-sm);margin-top:var(--space-2xl); }

/* ─── 8. Casos ─── */
.caso-featured { background:var(--card-bg);border:1px solid var(--border-subtle);border-radius:clamp(16px,5vw,32px);display:grid;grid-template-columns:1fr 360px;margin-bottom:var(--space-md);overflow:hidden; }
.caso-featured-text { padding:var(--space-2xl);display:flex;flex-direction:column;gap:var(--space-lg); }
.caso-co { font-family:var(--font-display);font-weight:500;font-size:1.3rem; }
.caso-quote { font-family:var(--font-display);font-weight:500;font-size:clamp(1.4rem,2.2vw,1.75rem);line-height:1.25;letter-spacing:-.01em; }
.caso-quote::before { content:open-quote; }
.caso-quote::after  { content:close-quote; }
.caso-link { font-family:var(--font-body);font-size:.9375rem;font-weight:500;color:var(--color-primary);text-decoration:none; }
.caso-link:hover { text-decoration:underline; }
.caso-link--sm { font-size:.875rem; }
.caso-featured-img { background:linear-gradient(135deg,var(--color-lavender-fill),var(--color-primary));display:flex;align-items:center;justify-content:center; }
.caso-stat { display:flex;flex-direction:column;align-items:center;gap:4px; }
.caso-stat-num { font-family:var(--font-display);font-weight:700;font-size:3.5rem;color:#fff;line-height:1;letter-spacing:-.03em; }
.caso-stat-lbl { font-family:var(--font-body);font-size:.8125rem;font-weight:500;color:rgba(255,255,255,.75);text-align:center;line-height:1.4; }
.casos-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-md); }
.caso-mini { background:var(--card-bg);border:1px solid var(--border-subtle);border-radius:clamp(16px,5vw,32px);padding:var(--space-xl);display:flex;flex-direction:column;gap:var(--space-sm); }
.caso-mini-co { font-family:var(--font-body);font-size:.8rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--color-coral); }
.caso-mini-text { font-family:var(--font-body);font-size:.9375rem;color:var(--color-ink);line-height:1.55;flex:1; }
.ticker { margin-top:var(--space-xl);overflow:hidden;position:relative;padding-top:var(--space-lg);border-top:1px solid var(--border-subtle); }
.ticker::before,.ticker::after { content:"";position:absolute;top:var(--space-lg);width:80px;height:100%;z-index:2;pointer-events:none; }
.ticker::before { left:0;background:linear-gradient(to right,var(--section-bg),transparent); }
.ticker::after  { right:0;background:linear-gradient(to left,var(--section-bg),transparent); }
.ticker-track { display:flex;align-items:center;gap:var(--space-3xl);animation:ticker 28s linear infinite;width:max-content; }
.ticker-track:hover { animation-play-state:paused; }
@keyframes ticker { from { transform:translateX(0); } to { transform:translateX(-50%); } }
.ticker-item { font-family:var(--font-body);font-size:.8rem;font-weight:500;color:var(--color-text-secondary);white-space:nowrap; }
.casos-cta { text-align:center;margin-top:var(--space-2xl); }

/* ─── 9. FAQ ─── */
.faq-wrap { max-width:720px;margin:0 auto; }
.faq-item { border-bottom:1px solid var(--border-subtle); }
.faq-q { display:flex;justify-content:space-between;align-items:center;width:100%;padding:var(--space-lg) 0;cursor:pointer;font-family:var(--font-body);font-size:1.0625rem;font-weight:500;color:var(--color-ink);background:none;border:none;text-align:left;gap:var(--space-md); }
.faq-q:hover { color:var(--color-primary); }
.faq-ico { width:24px;height:24px;border-radius:50%;background:var(--color-canvas);display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:700;flex-shrink:0;transition:transform .2s,background .2s; }
.faq-q[aria-expanded="true"] .faq-ico { transform:rotate(45deg);background:var(--color-primary);color:#fff; }
.faq-a { overflow:hidden;font-family:var(--font-body);font-size:.9375rem;color:var(--color-text-secondary);line-height:1.7;max-height:0;transition:max-height .3s ease,padding-bottom .3s; }
.faq-cta { text-align:center;margin-top:var(--space-3xl); }

/* ─── 10. Lead ─── */
.lead-container { display:flex;justify-content:center; }
.lead-card { background:var(--card-bg);border:1px solid var(--border-subtle);border-radius:clamp(16px,5vw,32px);padding:var(--space-3xl);max-width:600px;width:100%; }
.lead-hdr { text-align:center;margin-bottom:var(--space-xl); }
.lead-checks { display:flex;flex-direction:column;gap:var(--space-xs);margin-bottom:var(--space-xl); }
.lead-chk { display:flex;align-items:flex-start;gap:var(--space-xs);font-family:var(--font-body);font-size:.9rem;color:var(--color-text-secondary); }
.lead-chk-dot { width:18px;height:18px;border-radius:50%;background:var(--color-primary);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px; }
.lead-chk-dot svg { width:10px;height:10px; }
.lead-fields { display:flex;flex-direction:column;gap:var(--space-sm);margin-bottom:var(--space-md); }
.lead-input { width:100%;padding:var(--space-sm) var(--space-md);border:1px solid var(--border-medium);border-radius:var(--radius-input);font-family:var(--font-body);font-size:.9375rem;background:var(--color-surface);color:var(--color-ink);outline:none;transition:border-color .15s; }
.lead-input:focus { border-color:var(--color-primary); }
.lead-input::placeholder { color:#bbb; }
.lead-submit { width:100%;padding:var(--space-md);border-radius:var(--radius-button);background:var(--color-primary);color:#fff;font-family:var(--font-body);font-size:1.0625rem;font-weight:500;border:none;cursor:pointer;transition:background .15s,opacity .15s; }
.lead-submit:hover:not(:disabled) { background:var(--color-primary-hover); }
.lead-submit:disabled { opacity:0.38;cursor:default; }
.lead-micro { text-align:center;font-family:var(--font-body);font-size:.75rem;color:#bbb;margin-top:var(--space-sm); }

/* ─── Responsive ─── */
@media (max-width:768px) {
  .why-grid,.ft-panel--active,.caso-featured,.proceso-grid,.casos-grid { grid-template-columns:1fr; }
  .rubros-outer { grid-template-columns:1fr; }
  .rubros-left { display:none; }
  .rubros-right { gap:var(--space-xl); }
  .rblock { background:var(--card-bg);border:1px solid var(--border-subtle);border-radius:clamp(16px,5vw,32px);padding:var(--space-xl); }
  .metrics-row { grid-template-columns:repeat(2,1fr); }
  .roi-body { grid-template-columns:1fr; }
  .roi-left { padding-right:0;border-right:none;border-bottom:1px solid var(--border-subtle);padding-bottom:var(--space-xl);margin-bottom:var(--space-xl); }
  .roi-right { padding-left:0; }
  .db-grid { grid-template-columns:1fr; }
  .db-sidebar { display:none; }
  .db-kpis { grid-template-columns:repeat(2,1fr); }
}
</style>

<style is:global>
.roi-mod { display:flex;align-items:center;gap:var(--space-xs);padding:7px 0;border-bottom:.5px solid var(--border-subtle);cursor:pointer;user-select:none; }
.roi-mod:nth-last-child(-n+3) { border-bottom:none; }
.roi-mod input { display:none; }
.roi-cb { width:14px;height:14px;border-radius:3px;border:1.5px solid var(--border-medium);background:var(--color-surface);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:background .15s,border-color .15s; }
.roi-mod input:checked + .roi-cb { background:var(--color-primary);border-color:var(--color-primary); }
.roi-mod input:checked + .roi-cb::after { content:"";width:8px;height:5px;border:1.5px solid #fff;border-top:none;border-right:none;transform:rotate(-45deg) translate(.5px,-1px);display:block; }
.roi-mod-name  { font-family:var(--font-body);font-size:.8125rem;font-weight:500;color:var(--color-ink);flex:1; }
.roi-mod-price { font-family:var(--font-body);font-size:.75rem;color:var(--color-text-secondary); }
</style>

<script>
/* ── FEATURE TABS ──────────────────────────────────────────── */
(function () {
  const tabs   = document.querySelectorAll<HTMLButtonElement>('.ft-tab');
  const panels = document.querySelectorAll<HTMLElement>('.ft-panel');
  const dots   = document.querySelectorAll<HTMLButtonElement>('.ft-dot-btn');
  function setActive(i: number) {
    tabs.forEach((t, j)   => { t.classList.toggle('ft-tab--active', j === i);   t.setAttribute('aria-selected', j === i ? 'true' : 'false'); });
    panels.forEach((p, j) => p.classList.toggle('ft-panel--active', j === i));
    dots.forEach((d, j)   => d.classList.toggle('ft-dot-active', j === i));
  }
  tabs.forEach((tab, i) => tab.addEventListener('click', () => setActive(i)));
  dots.forEach((dot, i) => dot.addEventListener('click', () => setActive(i)));
})();

/* ── RUBROS ────────────────────────────────────────────────── */
(function () {
  const chips  = document.querySelectorAll<HTMLButtonElement>('.rchip');
  const blocks = document.querySelectorAll<HTMLElement>('.rblock');
  const NAV    = 88;
  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      const target = document.getElementById(chip.dataset.target!);
      if (!target) return;
      window.scrollTo({ top: target.getBoundingClientRect().top + scrollY - NAV, behavior: 'smooth' });
    });
  });
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting)
        chips.forEach(c => c.classList.toggle('rchip--active', c.dataset.target === e.target.id));
    });
  }, { rootMargin: `-${NAV}px 0px -10% 0px`, threshold: 0 });
  blocks.forEach(b => obs.observe(b));
})();

/* ── FAQ ───────────────────────────────────────────────────── */
(function () {
  function openItem(item: HTMLElement) {
    const btn = item.querySelector<HTMLButtonElement>('.faq-q')!;
    const ans = item.querySelector<HTMLElement>('.faq-a')!;
    btn.setAttribute('aria-expanded', 'true');
    ans.style.maxHeight     = ans.scrollHeight + 'px';
    ans.style.paddingBottom = '22px';
  }
  function closeAll() {
    document.querySelectorAll<HTMLElement>('.faq-item').forEach(it => {
      it.querySelector<HTMLButtonElement>('.faq-q')!.setAttribute('aria-expanded','false');
      const a = it.querySelector<HTMLElement>('.faq-a')!;
      a.style.maxHeight     = '0';
      a.style.paddingBottom = '0';
    });
  }
  document.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
    item.querySelector<HTMLButtonElement>('.faq-q')!.addEventListener('click', () => {
      const isOpen = item.querySelector<HTMLButtonElement>('.faq-q')!.getAttribute('aria-expanded') === 'true';
      closeAll();
      if (!isOpen) openItem(item);
    });
  });
  // Abrir el primer item por defecto
  const first = document.querySelector<HTMLElement>('.faq-item');
  if (first) openItem(first);
})();

/* ── LEAD FORM VALIDATION ──────────────────────────────────── */
(function () {
  const nameEl    = document.getElementById('lead-name')    as HTMLInputElement;
  const emailEl   = document.getElementById('lead-email')   as HTMLInputElement;
  const companyEl = document.getElementById('lead-company') as HTMLInputElement;
  const btn       = document.getElementById('lead-submit')  as HTMLButtonElement;
  if (!nameEl || !emailEl || !companyEl || !btn) return;

  function validate() {
    const nameOk    = nameEl.value.trim().length > 0;
    const emailOk   = emailEl.value.includes('@') && emailEl.value.includes('.');
    const companyOk = companyEl.value.trim().length > 0;
    btn.disabled = !(nameOk && emailOk && companyOk);
  }

  [nameEl, emailEl, companyEl].forEach(el => el.addEventListener('input', validate));
})();

/* ── ROI CALCULATOR ────────────────────────────────────────── */
(function () {
  const MODS = [
    {n:'CRM',p:25,d:1},{n:'Ventas',p:20,d:1},{n:'Contabilidad',p:30,d:1},
    {n:'Compras',p:15,d:0},{n:'Inventario',p:20,d:0},{n:'Proyectos',p:15,d:0},
    {n:'RRHH',p:20,d:0},{n:'Manufactura',p:25,d:0},{n:'Sitio web',p:20,d:0},
    {n:'Email marketing',p:15,d:0},{n:'Punto de venta',p:20,d:0},{n:'Servicio externo',p:15,d:0},
  ];
  const fmt = (n: number) => 'USD ' + Math.round(n).toLocaleString('es-AR').replace(/,/g,'.');
  const getPlan = (u: number) => {
    if (u<=4)  return {nombre:'Plan Starter', precio:11,  impl:0,    desc:'Accedé a las apps esenciales sin contratos largos.'};
    if (u<=20) return {nombre:'Plan Pyme',    precio:100, impl:1500, desc:'Te acompañamos para que tu equipo adopte Odoo sin fricciones.'};
    if (u<=50) return {nombre:'Plan Empresa', precio:450, impl:7500, desc:'Proyecto end-to-end con relevamiento, desarrollo a medida y soporte.'};
    return           {nombre:'Plan Corp.',   precio:null,impl:null,  desc:'Cada proyecto es único. Te presentamos una propuesta integral.'};
  };
  const root = document.getElementById('roi-mods');
  if (!root) return;
  root.innerHTML = MODS.map((m,i)=>`<label class="roi-mod"><input type="checkbox" data-i="${i}" data-p="${m.p}" ${m.d?'checked':''}><span class="roi-cb"></span><span class="roi-mod-name">${m.n}</span><span class="roi-mod-price">USD ${m.p}</span></label>`).join('');
  const sl  = document.getElementById('roi-slider')   as HTMLInputElement;
  const uEl = document.getElementById('roi-users')!;
  const dPl = document.getElementById('roi-detected-pill')!;
  const cCr = document.getElementById('roi-cost-current')!;
  const cAd = document.getElementById('roi-cost-adhoc')!;
  const cSv = document.getElementById('roi-savings')!;
  const hPl = document.getElementById('roi-hero-pill')!;
  const hPr = document.getElementById('roi-hero-price')!;
  const hIm = document.getElementById('roi-hero-impl')!;
  const hDs = document.getElementById('roi-hero-desc')!;
  const swap = (el:HTMLElement, v:string) => { el.style.opacity='0'; setTimeout(()=>{el.textContent=v;el.style.opacity='1';},90); };
  const update = () => {
    const u = +sl.value; uEl.textContent = String(u);
    const checked = [...root.querySelectorAll<HTMLInputElement>('input:checked')];
    const sum = checked.reduce((a,c)=>a+Number(c.dataset.p),0);
    const plan = getPlan(u);
    dPl.textContent = hPl.textContent = plan.nombre;
    if (!checked.length) { [cCr,cAd,cSv].forEach(e=>swap(e,'—')); hPr.textContent='—'; hIm.textContent='Seleccioná módulos.'; hDs.textContent=plan.desc; return; }
    swap(cCr, fmt(sum*u));
    if (plan.precio===null) { swap(cAd,'A consultar'); swap(cSv,'Hablemos :)'); hPr.textContent='Cotización personalizada'; hIm.style.display='none'; }
    else { hIm.style.display=''; swap(cAd,fmt(plan.precio)); swap(cSv,fmt((sum*u-plan.precio)*12)); hPr.textContent=fmt(plan.precio)+' / mes'; hIm.textContent=plan.impl===0?'Sin costo de implementación':'+ '+fmt(plan.impl)+' implementación única'; }
    hDs.textContent = plan.desc;
  };
  root.addEventListener('change', update);
  sl.addEventListener('input', update);
  update();
})();
</script>
