---
// Cotizador.astro — Modal multi-step
// Siempre en el DOM. Se muestra/oculta con aria-hidden + display en el overlay.
---

<div
  id="cotizador-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Cotizador de plan Adhoc"
  aria-hidden="true"
>
  <div id="cotizador-modal">

    <!-- Progress bar -->
    <div class="cot-progress" aria-hidden="true">
      <div class="cot-progress-fill" id="cot-progress-fill"></div>
    </div>

    <!-- Close -->
    <button class="cot-close" id="cot-close" aria-label="Cerrar cotizador">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="3" x2="15" y2="15"/>
        <line x1="15" y1="3" x2="3" y2="15"/>
      </svg>
    </button>

    <!-- ══ PASO 1 — Rubro ════════════════════════════════ -->
    <div class="cot-step" data-step="1">
      <div class="cot-step-header">
        <span class="cot-step-num">Pregunta 1 de 3</span>
        <h2 class="cot-question">¿En qué rubro opera tu empresa?</h2>
        <p class="cot-hint">Esto nos ayuda a recomendarte los módulos correctos.</p>
      </div>

      <div class="cot-options">
        <button class="cot-opt" data-value="manufactura">
          <span class="cot-opt-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93A10 10 0 0 0 12 2v2a8 8 0 0 1 5.66 2.34M4.93 4.93A10 10 0 0 0 2 12h2a8 8 0 0 1 2.34-5.66M4.93 19.07A10 10 0 0 0 12 22v-2a8 8 0 0 1-5.66-2.34M19.07 19.07A10 10 0 0 0 22 12h-2a8 8 0 0 1-2.34 5.66"/></svg>
          </span>
          <span class="cot-opt-label">Manufactura</span>
        </button>
        <button class="cot-opt" data-value="comercializadora">
          <span class="cot-opt-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          </span>
          <span class="cot-opt-label">Distribución y comercios</span>
        </button>
        <button class="cot-opt" data-value="servicios">
          <span class="cot-opt-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
          </span>
          <span class="cot-opt-label">Servicios</span>
        </button>
        <button class="cot-opt" data-value="educacion">
          <span class="cot-opt-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 2 9 2 12 0v-5"/></svg>
          </span>
          <span class="cot-opt-label">Educación</span>
        </button>
      </div>

      <div class="cot-footer">
        <span class="cot-back" style="visibility:hidden" aria-hidden="true"></span>
        <span></span>
      </div>
    </div>

    <!-- ══ PASO 2 — Herramienta ══════════════════════════ -->
    <div class="cot-step" data-step="2">
      <div class="cot-step-header">
        <span class="cot-step-num">Pregunta 2 de 3</span>
        <h2 class="cot-question">¿Qué herramienta usás hoy para gestionar tu empresa?</h2>
        <p class="cot-hint">Sin filtros — toda respuesta nos ayuda.</p>
      </div>

      <div class="cot-options">
        <button class="cot-opt" data-value="excel">
          <span class="cot-opt-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18"/></svg>
          </span>
          <span class="cot-opt-label">Excel / Google Sheets</span>
        </button>
        <button class="cot-opt" data-value="erp">
          <span class="cot-opt-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
          </span>
          <span class="cot-opt-label">Sistema actual (ERP)</span>
        </button>
        <button class="cot-opt" data-value="varios">
          <span class="cot-opt-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></svg>
          </span>
          <span class="cot-opt-label">Varios sistemas desconectados</span>
        </button>
        <button class="cot-opt" data-value="nada">
          <span class="cot-opt-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </span>
          <span class="cot-opt-label">Nada formal</span>
        </button>
      </div>

      <div class="cot-footer">
        <button class="cot-back" data-back>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9,3 5,7 9,11"/></svg>
          Atrás
        </button>
        <span></span>
      </div>
    </div>

    <!-- ══ PASO 3 — Usuarios ═════════════════════════════ -->
    <div class="cot-step" data-step="3">
      <div class="cot-step-header">
        <span class="cot-step-num">Pregunta 3 de 3</span>
        <h2 class="cot-question">¿Cuántos usuarios necesitarían acceso?</h2>
        <p class="cot-hint">Elegí el rango más cercano a tu equipo actual.</p>
      </div>

      <div class="cot-options">
        <button class="cot-opt" data-value="1-4">
          <span class="cot-opt-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </span>
          <span class="cot-opt-label">1–4 personas</span>
        </button>
        <button class="cot-opt" data-value="5-30">
          <span class="cot-opt-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </span>
          <span class="cot-opt-label">5–30 personas</span>
        </button>
        <button class="cot-opt" data-value="30-50">
          <span class="cot-opt-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          </span>
          <span class="cot-opt-label">30–50 personas</span>
        </button>
        <button class="cot-opt" data-value="50+">
          <span class="cot-opt-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </span>
          <span class="cot-opt-label">50+ personas</span>
        </button>
      </div>

      <div class="cot-footer">
        <button class="cot-back" data-back>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9,3 5,7 9,11"/></svg>
          Atrás
        </button>
        <span></span>
      </div>
    </div>

    <!-- ══ RESULTADO ══════════════════════════════════════ -->
    <div class="cot-step" data-step="4">
      <div class="cot-step-header">
        <span class="cot-step-num">Tu plan recomendado</span>
        <h2 class="cot-question" id="cot-result-headline">Acá está tu plan.</h2>
      </div>

      <div class="cot-result-card">
        <div>
          <span class="cot-result-tag">Recomendado para vos</span>
          <div class="cot-result-plan" id="cot-result-name">Plan Growth</div>
          <p class="cot-result-desc" id="cot-result-desc"></p>
        </div>
        <div class="cot-result-bullets" id="cot-result-bullets"></div>
        <div class="cot-result-ctas">
          <a href="#" class="cot-btn-primary" id="cot-cta-agenda">Agendar llamada</a>
          <a href="#" class="cot-btn-outline" id="cot-cta-asesor">Hablar con un asesor</a>
        </div>
        <p class="cot-confirm-text">Nuestro equipo te va a contactar en menos de 24 horas.</p>
      </div>

      <div class="cot-footer">
        <button class="cot-back" data-back>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9,3 5,7 9,11"/></svg>
          Atrás
        </button>
        <span></span>
      </div>
    </div>

  </div><!-- /modal -->
</div><!-- /overlay -->

<style is:global>
/* ─── Overlay ────────────────────────────────────────────── */
#cotizador-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  align-items: center;
  justify-content: center;
  padding: var(--space-lg);
}

#cotizador-overlay.cot-open {
  display: flex;
}

/* ─── Modal card ─────────────────────────────────────────── */
#cotizador-modal {
  background: var(--color-surface);
  border: 1px solid var(--border-subtle);
  border-radius: clamp(20px, 3vw, 32px);
  padding: 40px;
  max-width: 560px;
  width: 100%;
  position: relative;
  max-height: 90vh;
  overflow-y: auto;
  /* NO box-shadow */
}

/* ─── Progress bar ───────────────────────────────────────── */
.cot-progress {
  height: 4px;
  background: var(--border-subtle);
  border-radius: 2px;
  margin-bottom: var(--space-xl);
  overflow: hidden;
}

.cot-progress-fill {
  height: 100%;
  background: var(--color-primary);
  width: 33%;
  transition: width 300ms ease;
  border-radius: 2px;
}

/* ─── Close button ───────────────────────────────────────── */
.cot-close {
  position: absolute;
  top: var(--space-md);
  right: var(--space-md);
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-text-secondary);
  padding: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-input);
  transition: color 0.15s, background 0.15s;
}

.cot-close:hover {
  color: var(--color-ink);
  background: var(--color-canvas);
}

/* ─── Steps ──────────────────────────────────────────────── */
.cot-step {
  display: none;
  flex-direction: column;
  gap: var(--space-xl);
  animation: cotFadeUp 0.3s cubic-bezier(0.4, 0, 0.2, 1) both;
}

.cot-step.cot-active {
  display: flex;
}

@keyframes cotFadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ─── Step header ────────────────────────────────────────── */
.cot-step-header {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.cot-step-num {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--color-primary);
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.cot-question {
  font-family: var(--font-display);
  font-weight: 500;
  font-size: clamp(1.5rem, 4vw, 2rem);
  line-height: 1.2;
  letter-spacing: -0.01em;
  color: var(--color-ink);
}

.cot-hint {
  font-family: var(--font-body);
  font-size: 0.9375rem;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

/* ─── Options grid ───────────────────────────────────────── */
.cot-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-sm);
}

/* ─── Option card ────────────────────────────────────────── */
.cot-opt {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-xs);
  padding: var(--space-lg);
  background: var(--color-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-button);
  cursor: pointer;
  text-align: left;
  width: 100%;
  transition: border-color 0.15s, background 0.15s, transform 0.1s;
}

.cot-opt:hover {
  background: var(--color-lavender-fill);
  border-color: var(--border-medium);
}

.cot-opt:active {
  transform: scale(0.98);
}

/* Excepción documentada: border violeta SOLO en card seleccionada del cotizador */
.cot-opt.cot-selected {
  border-color: var(--color-primary);
  background: var(--color-lavender-fill);
}

.cot-opt-icon {
  width: 28px;
  height: 28px;
  color: var(--color-ink);
  flex-shrink: 0;
}

.cot-opt-label {
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--color-ink);
  line-height: 1.3;
}

/* ─── Footer ─────────────────────────────────────────────── */
.cot-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 40px;
  padding-top: var(--space-xs);
}

.cot-back {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text-secondary);
  background: none;
  border: none;
  cursor: pointer;
  padding: 8px 0;
  transition: color 0.15s;
}

.cot-back:hover { color: var(--color-ink); }

/* ─── Result ─────────────────────────────────────────────── */
.cot-result-card {
  background: var(--color-canvas);
  border: 1px solid var(--border-subtle);
  border-radius: clamp(16px, 3vw, 24px);
  padding: var(--space-xl);
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
}

.cot-result-tag {
  display: inline-block;
  font-family: var(--font-body);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--color-lavender);
  background: var(--color-lavender-fill);
  padding: 4px 10px;
  border-radius: var(--radius-tag);
  margin-bottom: var(--space-xs);
}

.cot-result-plan {
  font-family: var(--font-display);
  font-weight: 500;
  font-size: 1.75rem;
  line-height: 1.15;
  letter-spacing: -0.01em;
  color: var(--color-ink);
}

.cot-result-desc {
  font-family: var(--font-body);
  font-size: 0.9rem;
  color: var(--color-text-secondary);
  line-height: 1.55;
  margin-top: var(--space-xs);
}

.cot-result-bullets {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.cot-bullet {
  display: flex;
  align-items: flex-start;
  gap: var(--space-xs);
  font-family: var(--font-body);
  font-size: 0.9rem;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.cot-bullet-dot {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 1px;
}

.cot-result-ctas {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.cot-btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-sm) var(--space-lg);
  border-radius: var(--radius-button);
  background: var(--color-primary);
  color: #fff;
  font-family: var(--font-body);
  font-size: 1rem;
  font-weight: 500;
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: background 0.15s;
}

.cot-btn-primary:hover { background: var(--color-primary-hover); }

.cot-btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-sm) var(--space-lg);
  border-radius: var(--radius-button);
  background: transparent;
  color: var(--color-ink);
  font-family: var(--font-body);
  font-size: 1rem;
  font-weight: 500;
  border: 1px solid var(--border-subtle);
  cursor: pointer;
  text-decoration: none;
  transition: background 0.15s;
}

.cot-btn-outline:hover { background: var(--color-canvas); }

.cot-confirm-text {
  text-align: center;
  font-family: var(--font-body);
  font-size: 0.8125rem;
  color: var(--color-text-secondary);
}

/* ─── Mobile ─────────────────────────────────────────────── */
@media (max-width: 600px) {
  #cotizador-modal {
    padding: 24px;
  }

  .cot-options {
    grid-template-columns: 1fr;
  }

  .cot-question {
    font-size: 1.5rem;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const overlay      = document.getElementById('cotizador-overlay')!;
  const modal        = document.getElementById('cotizador-modal')!;
  const closeBtn     = document.getElementById('cot-close')!;
  const progressFill = document.getElementById('cot-progress-fill')!;

  // ── State ────────────────────────────────────────────────
  let state = { rubro: '', herramienta: '', users: '' };
  let currentStep = 1;

  // ── Plans ────────────────────────────────────────────────
  const PLANS: Record<string, { name: string; desc: string; bullets: string[] }> = {
    '1-4': {
      name: 'Plan Start',
      desc: 'Ideal para equipos pequeños que quieren empezar a ordenar su operación sin complejidad.',
      bullets: [
        'Módulos esenciales configurados y listos para usar',
        'Implementación guiada en 4 semanas',
        'Soporte por email y chat en horario comercial',
      ],
    },
    '5-30': {
      name: 'Plan Growth',
      desc: 'Para PyMEs en crecimiento que necesitan integrar todas sus áreas en un solo sistema.',
      bullets: [
        'Implementación completa adaptada a tu rubro',
        'Migración de datos y capacitación del equipo incluida',
        'Soporte consultivo con especialista asignado',
      ],
    },
    '30+': {
      name: 'Plan Enterprise',
      desc: 'Para empresas consolidadas que necesitan escalar sin reescribir procesos.',
      bullets: [
        'Proyecto end-to-end con relevamiento profundo',
        'Desarrollos a medida y automatizaciones avanzadas',
        'Especialista dedicado con SLA garantizado',
      ],
    },
  };

  // ── Helpers ──────────────────────────────────────────────
  function openModal() {
    overlay.classList.add('cot-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    showStep(1);
    // Focus first option after animation
    setTimeout(() => {
      const first = modal.querySelector<HTMLElement>('.cot-step.cot-active .cot-opt');
      first?.focus();
    }, 80);
  }

  function closeModal() {
    overlay.classList.remove('cot-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    resetFlow();
  }

  function resetFlow() {
    state = { rubro: '', herramienta: '', users: '' };
    modal.querySelectorAll('.cot-opt').forEach(o => o.classList.remove('cot-selected'));
    showStep(1, false);
  }

  function showStep(n: number, animate = true) {
    currentStep = n;
    modal.querySelectorAll('.cot-step').forEach(s => {
      s.classList.remove('cot-active');
    });
    const target = modal.querySelector<HTMLElement>(`.cot-step[data-step="${n}"]`);
    if (!target) return;

    // Re-trigger animation by cloning or toggling a class
    if (animate) {
      target.style.animation = 'none';
      // Force reflow
      void (target as HTMLElement).offsetHeight;
      target.style.animation = '';
    }
    target.classList.add('cot-active');

    // Progress: steps 1/2/3 → 33%/66%/100%, result → 100%
    const pct = n === 4 ? 100 : Math.round((n / 3) * 100);
    progressFill.style.width = pct + '%';
  }

  function computeResult() {
    const planKey = state.users === '1-4' ? '1-4' : state.users === '5-30' ? '5-30' : '30+';
    const plan = PLANS[planKey];

    const nameEl    = document.getElementById('cot-result-name');
    const descEl    = document.getElementById('cot-result-desc');
    const bulletsEl = document.getElementById('cot-result-bullets');

    if (nameEl)    nameEl.textContent = plan.name;
    if (descEl)    descEl.textContent = plan.desc;
    if (bulletsEl) bulletsEl.innerHTML = plan.bullets
      .map(b => `
        <div class="cot-bullet">
          <span class="cot-bullet-dot">
            <svg viewBox="0 0 10 10" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="2,5 4,7 8,3"/>
            </svg>
          </span>
          <span>${b}</span>
        </div>`)
      .join('');

    // Log para conectar backend
    console.log('[Cotizador] Respuestas:', { ...state }, '→ Plan recomendado:', plan.name);
  }

  // ── Triggers ─────────────────────────────────────────────
  document.querySelectorAll('[data-open-cotizador="true"]').forEach(el => {
    el.addEventListener('click', openModal);
  });

  // ── Close ────────────────────────────────────────────────
  closeBtn.addEventListener('click', closeModal);

  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay.classList.contains('cot-open')) closeModal();
  });

  // ── Back buttons ─────────────────────────────────────────
  modal.querySelectorAll<HTMLButtonElement>('[data-back]').forEach(btn => {
    btn.addEventListener('click', () => {
      if (currentStep > 1) showStep(currentStep - 1);
    });
  });

  // ── Step 1 — Rubro ───────────────────────────────────────
  modal.querySelectorAll<HTMLButtonElement>('[data-step="1"] .cot-opt').forEach(card => {
    card.addEventListener('click', () => {
      modal.querySelectorAll('[data-step="1"] .cot-opt').forEach(c => c.classList.remove('cot-selected'));
      card.classList.add('cot-selected');
      state.rubro = card.dataset.value!;
      setTimeout(() => showStep(2), 220);
    });
  });

  // ── Step 2 — Herramienta ─────────────────────────────────
  modal.querySelectorAll<HTMLButtonElement>('[data-step="2"] .cot-opt').forEach(card => {
    card.addEventListener('click', () => {
      modal.querySelectorAll('[data-step="2"] .cot-opt').forEach(c => c.classList.remove('cot-selected'));
      card.classList.add('cot-selected');
      state.herramienta = card.dataset.value!;
      setTimeout(() => showStep(3), 220);
    });
  });

  // ── Step 3 — Usuarios ────────────────────────────────────
  modal.querySelectorAll<HTMLButtonElement>('[data-step="3"] .cot-opt').forEach(card => {
    card.addEventListener('click', () => {
      modal.querySelectorAll('[data-step="3"] .cot-opt').forEach(c => c.classList.remove('cot-selected'));
      card.classList.add('cot-selected');
      state.users = card.dataset.value!;
      computeResult();
      setTimeout(() => showStep(4), 220);
    });
  });
});
</script>
