---
interface Props {
  currentPage?: string;
}
const { currentPage = '' } = Astro.props;
---

<header id="nav">
  <div class="nav-inner container">
    <a href="/" class="nav-logo" aria-label="Adhoc — inicio">
      <img src="/logos/logo-primary.svg" alt="Adhoc" width="120" height="40">
    </a>

    <nav class="nav-links" aria-label="Navegación principal">

      <!-- Soluciones -->
      <div class="nav-item" id="ni-sol">
        <button class="nav-trigger" id="t-sol" aria-haspopup="true" aria-expanded="false">
          Soluciones
          <span class="chev-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4,6 8,10 12,6"/></svg>
          </span>
        </button>
        <div class="dropdown" id="dd-sol" role="menu">
          <div class="dd-cols dd-cols-3">
            <div class="dd-col">
              <div class="dd-col-label">Operaciones</div>
              <a class="dd-item" href="#" role="menuitem">
                <div class="dd-icon dd-icon--coral">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="11" width="3" height="7" rx="1"/><rect x="8.5" y="7" width="3" height="11" rx="1"/><rect x="15" y="3" width="3" height="15" rx="1"/></svg>
                </div>
                <div class="dd-text">
                  <div class="dd-name">Ventas y CRM</div>
                  <div class="dd-desc">Gestioná tu pipeline</div>
                </div>
              </a>
              <a class="dd-item" href="#" role="menuitem">
                <div class="dd-icon dd-icon--violet">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="16" height="13" rx="2"/><path d="M2 5l2-3h12l2 3"/><path d="M7 10h6"/></svg>
                </div>
                <div class="dd-text">
                  <div class="dd-name">Inventario</div>
                  <div class="dd-desc">Control en tiempo real</div>
                </div>
              </a>
              <a class="dd-item" href="#" role="menuitem">
                <div class="dd-icon dd-icon--mustard">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 1h2.5l2 9h9l2-6H5.5"/><circle cx="8" cy="17" r="1.2"/><circle cx="15" cy="17" r="1.2"/></svg>
                </div>
                <div class="dd-text">
                  <div class="dd-name">Compras</div>
                  <div class="dd-desc">Optimizá proveedores</div>
                </div>
              </a>
              <a class="dd-item" href="#" role="menuitem">
                <div class="dd-icon dd-icon--lavender">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2h12v14l-2-1.5L12 16l-2-1.5L8 16l-2-1.5L4 16V2z"/><path d="M7 7h6M7 10h6M7 13h4"/></svg>
                </div>
                <div class="dd-text">
                  <div class="dd-name">Finanzas</div>
                  <div class="dd-desc">Automatizá tu contabilidad</div>
                </div>
              </a>
            </div>

            <div class="dd-col">
              <div class="dd-col-label">Gestión</div>
              <a class="dd-item" href="#" role="menuitem">
                <div class="dd-icon dd-icon--coral">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="6" r="3"/><path d="M2 18c0-3.3 2.7-6 6-6s6 2.7 6 6"/><circle cx="15" cy="6" r="2.5"/><path d="M18 18c0-2.8-1.6-5-4-5.7"/></svg>
                </div>
                <div class="dd-text">
                  <div class="dd-name">Recursos Humanos</div>
                  <div class="dd-desc">Empleados y liquidaciones</div>
                </div>
              </a>
              <a class="dd-item" href="#" role="menuitem">
                <div class="dd-icon dd-icon--violet">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2s4 1 5 6l-3 3-4-4 2-5z"/><path d="M7 11l2 2-4 5-1-1 3-6z"/><path d="M13 7l-2 2"/></svg>
                </div>
                <div class="dd-text">
                  <div class="dd-name">Proyectos</div>
                  <div class="dd-desc">Planificá y ejecutá</div>
                </div>
              </a>
              <a class="dd-item" href="#" role="menuitem">
                <div class="dd-icon dd-icon--mustard">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7l2-4h12l2 4"/><path d="M2 7c0 1.7 1.3 3 3 3s3-1.3 3-3 1.3 3 3 3 3-1.3 3-3 1.3 3 3 3"/><path d="M3 10v8h14v-8"/><path d="M8 18v-5h4v5"/></svg>
                </div>
                <div class="dd-text">
                  <div class="dd-name">E-commerce</div>
                  <div class="dd-desc">Vendé online con Odoo</div>
                </div>
              </a>
            </div>

            <div class="dd-col">
              <div class="dd-col-label">Plataforma</div>
              <a class="dd-item" href="#" role="menuitem">
                <div class="dd-icon dd-icon--lavender">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v3h3a2 2 0 010 4h-3v3h3a2 2 0 010 4H5a2 2 0 010-4h3v-3H5a2 2 0 010-4h3V3a2 2 0 014 0z"/></svg>
                </div>
                <div class="dd-text">
                  <div class="dd-name">Integraciones</div>
                  <div class="dd-desc">Conectá tus sistemas</div>
                </div>
              </a>
              <a class="dd-item" href="#" role="menuitem">
                <div class="dd-icon dd-icon--violet">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2l7 3v5c0 4-3 7-7 8-4-1-7-4-7-8V5l7-3z"/><polyline points="7,10 9,12 13,8"/></svg>
                </div>
                <div class="dd-text">
                  <div class="dd-name">Soporte continuo</div>
                  <div class="dd-desc">Siempre acompañados</div>
                </div>
              </a>
            </div>
          </div>

          <div class="dd-footer">
            <div class="dd-footer-left">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="10,2 12.5,7.5 18.5,8 14,12.5 15.5,18.5 10,15.5 4.5,18.5 6,12.5 1.5,8 7.5,7.5"/></svg>
              <span class="dd-footer-text"><strong>Partner #1 de Odoo</strong> — conocé por qué. <a href="#" class="dd-footer-link">Ver historia →</a></span>
            </div>
            <a href="#" class="dd-footer-link">Agendar diagnóstico gratuito →</a>
          </div>
        </div>
      </div>

      <a href="/pricing" class="nav-trigger" class:list={[{ 'nav-trigger--active': currentPage === 'pricing' }]}>Precios</a>
      <a href="#" class="nav-trigger">Casos</a>
      <a href="#" class="nav-trigger">Recursos</a>
    </nav>

    <div class="nav-ctas">
      <button class="btn btn--outline btn--sm">Ingresar</button>
      <button class="btn btn--primary btn--sm" id="cta-demo-nav" aria-label="Solicitar demo">
        Solicitar demo
      </button>
      <button class="nav-hamburger" id="mobile-open" aria-label="Abrir menú" aria-expanded="false" aria-controls="mob-drawer">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="7" x2="19" y2="7"/>
          <line x1="3" y1="11" x2="19" y2="11"/>
          <line x1="3" y1="15" x2="19" y2="15"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile overlay + drawer -->
<div class="mobile-overlay" id="mob-overlay" aria-hidden="true"></div>
<div class="mobile-drawer" id="mob-drawer" role="dialog" aria-modal="true" aria-label="Menú de navegación">
  <div class="drawer-handle" aria-hidden="true"></div>
  <button class="drawer-close" id="mob-close" aria-label="Cerrar menú">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><line x1="4" y1="4" x2="16" y2="16"/><line x1="16" y1="4" x2="4" y2="16"/></svg>
  </button>

  <div class="drawer-section" id="drs-sol">
    <button class="drawer-trigger" aria-expanded="false" aria-controls="drs-sol-content">
      Soluciones
      <span class="chev-icon" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4,6 8,10 12,6"/></svg></span>
    </button>
    <div class="drawer-content" id="drs-sol-content">
      <a class="drawer-item" href="#">Ventas y CRM</a>
      <a class="drawer-item" href="#">Inventario</a>
      <a class="drawer-item" href="#">Compras</a>
      <a class="drawer-item" href="#">Finanzas</a>
      <a class="drawer-item" href="#">Recursos Humanos</a>
      <a class="drawer-item" href="#">Proyectos</a>
    </div>
  </div>

  <a class="drawer-link" href="/pricing">Precios</a>
  <a class="drawer-link" href="#">Casos</a>
  <a class="drawer-link" href="#">Recursos</a>

  <div class="drawer-ctas">
    <button class="btn btn--primary btn--full">Solicitar demo</button>
    <button class="btn btn--outline btn--full">Ingresar</button>
  </div>
</div>

<style>
  /* ─── Nav shell ─── */
  #nav {
    position: sticky;
    top: 0;
    z-index: 200;
    background: var(--color-canvas);
    border-bottom: 1px solid var(--border-subtle);
    height: 64px;
  }

  .nav-inner {
    height: 64px;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    margin-right: 32px;
    flex-shrink: 0;
  }

  .nav-logo img {
    height: 40px;
    width: auto;
  }

  /* ─── Nav links ─── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2px;
    flex: 1;
  }

  .nav-item {
    position: relative;
  }

  .nav-trigger {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink);
    padding: 8px 14px;
    border-radius: 8px;
    background: transparent;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
    text-decoration: none;
  }

  .nav-trigger:hover {
    background: var(--color-surface);
  }

  .nav-trigger--active {
    color: var(--color-primary);
  }

  .chev-icon {
    display: inline-flex;
    align-items: center;
    opacity: 0.5;
    transition: transform 0.2s, opacity 0.2s;
  }

  .nav-item.open .chev-icon {
    transform: rotate(180deg);
    opacity: 0.8;
  }

  /* ─── CTAs ─── */
  .nav-ctas {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-left: auto;
  }

  .nav-hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    padding: 8px;
    background: none;
    border: none;
    cursor: pointer;
    border-radius: 8px;
  }

  .nav-hamburger:hover {
    background: var(--color-surface);
  }

  /* ─── Dropdown ─── */
  .dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    background: var(--color-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    padding: 16px 20px 14px;
    min-width: 680px;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-6px);
    transition: opacity 0.18s ease-out, transform 0.18s ease-out;
    z-index: 300;
  }

  .dropdown::before {
    content: "";
    position: absolute;
    top: -10px;
    left: 0;
    right: 0;
    height: 10px;
  }

  .dropdown.open {
    opacity: 1;
    pointer-events: all;
    transform: translateY(0);
  }

  .dd-cols {
    display: grid;
  }

  .dd-cols-3 {
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
  }

  .dd-col {
    padding: 0 4px;
  }

  .dd-col-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 6px;
    padding: 4px 8px;
  }

  .dd-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 7px 8px;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.1s;
    text-decoration: none;
    color: inherit;
  }

  .dd-item:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .dd-item:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .dd-icon {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    transition: transform 0.1s;
  }

  .dd-item:hover .dd-icon {
    transform: scale(1.08);
  }

  .dd-icon--coral   { background: #FFE5DE; }
  .dd-icon--coral svg { stroke: var(--color-coral); }
  .dd-icon--violet  { background: #EAE7FA; }
  .dd-icon--violet svg { stroke: var(--color-primary); }
  .dd-icon--mustard { background: #FFF3D0; }
  .dd-icon--mustard svg { stroke: #B87800; }
  .dd-icon--lavender { background: #F0EDFB; }
  .dd-icon--lavender svg { stroke: #9A8FDE; }

  .dd-name {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink);
    line-height: 1.3;
    margin-bottom: 1px;
  }

  .dd-desc {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.35;
  }

  .dd-footer {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .dd-footer-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .dd-footer-text {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .dd-footer-text strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  .dd-footer-link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.12s;
  }

  .dd-footer-link:hover {
    text-decoration: underline;
  }

  /* ─── Mobile overlay + drawer ─── */
  .mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: 400;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .mobile-overlay.open {
    display: block;
    opacity: 1;
  }

  .mobile-drawer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 500;
    background: var(--color-canvas);
    border-radius: 20px 20px 0 0;
    padding: 20px 0 40px;
    max-height: 85vh;
    overflow-y: auto;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .mobile-drawer.open {
    transform: translateY(0);
  }

  .drawer-handle {
    width: 36px;
    height: 4px;
    border-radius: 2px;
    background: var(--border-medium);
    margin: 0 auto 20px;
  }

  .drawer-close {
    position: absolute;
    top: 16px;
    right: 20px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: var(--color-text-muted);
  }

  .drawer-section {
    border-bottom: 1px solid var(--border-subtle);
  }

  .drawer-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 16px 24px;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }

  .drawer-content {
    display: none;
    padding: 0 24px 16px;
  }

  .drawer-section.open .drawer-content {
    display: flex;
    flex-direction: column;
  }

  .drawer-item {
    display: block;
    padding: 10px 0;
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    border-bottom: 1px solid #F0EDE8;
    text-decoration: none;
  }

  .drawer-item:last-child {
    border: none;
  }

  .drawer-link {
    display: block;
    padding: 16px 24px;
    font-weight: 500;
    font-size: 1rem;
    border-bottom: 1px solid var(--border-subtle);
    text-decoration: none;
    color: var(--color-ink);
  }

  .drawer-ctas {
    padding: 20px 24px 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* ─── Responsive ─── */
  @media (max-width: 767px) {
    .nav-links,
    .nav-ctas .btn--outline {
      display: none;
    }

    .nav-hamburger {
      display: flex;
    }
  }
</style>

<script>
  // Dropdown behavior
  const navItems = document.querySelectorAll<HTMLElement>('.nav-item');

  navItems.forEach(item => {
    const trigger = item.querySelector<HTMLButtonElement>('.nav-trigger');
    const dropdown = item.querySelector<HTMLElement>('.dropdown');
    if (!trigger || !dropdown) return;

    let closeTimer: ReturnType<typeof setTimeout>;

    const open = () => {
      clearTimeout(closeTimer);
      navItems.forEach(other => {
        if (other !== item) {
          other.classList.remove('open');
          other.querySelector('.dropdown')?.classList.remove('open');
          other.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false');
        }
      });
      item.classList.add('open');
      dropdown.classList.add('open');
      trigger.setAttribute('aria-expanded', 'true');
    };

    const close = () => {
      closeTimer = setTimeout(() => {
        item.classList.remove('open');
        dropdown.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
      }, 120);
    };

    item.addEventListener('mouseenter', open);
    item.addEventListener('mouseleave', close);
    trigger.addEventListener('click', () => {
      item.classList.contains('open') ? close() : open();
    });
    dropdown.addEventListener('mouseenter', () => clearTimeout(closeTimer));
    dropdown.addEventListener('mouseleave', close);
  });

  // Close on outside click
  document.addEventListener('click', e => {
    if (!(e.target as HTMLElement).closest('.nav-item')) {
      navItems.forEach(item => {
        item.classList.remove('open');
        item.querySelector('.dropdown')?.classList.remove('open');
        item.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false');
      });
    }
  });

  // Mobile drawer
  const overlay = document.getElementById('mob-overlay')!;
  const drawer = document.getElementById('mob-drawer')!;
  const openBtn = document.getElementById('mobile-open')!;
  const closeBtn = document.getElementById('mob-close')!;

  const openDrawer = () => {
    overlay.classList.add('open');
    drawer.classList.add('open');
    openBtn.setAttribute('aria-expanded', 'true');
    overlay.removeAttribute('aria-hidden');
  };

  const closeDrawer = () => {
    overlay.classList.remove('open');
    drawer.classList.remove('open');
    openBtn.setAttribute('aria-expanded', 'false');
    overlay.setAttribute('aria-hidden', 'true');
  };

  openBtn.addEventListener('click', openDrawer);
  closeBtn.addEventListener('click', closeDrawer);
  overlay.addEventListener('click', closeDrawer);

  // Drawer accordion
  document.querySelectorAll<HTMLElement>('.drawer-section').forEach(section => {
    const trigger = section.querySelector<HTMLButtonElement>('.drawer-trigger');
    if (!trigger) return;
    trigger.addEventListener('click', () => {
      const isOpen = section.classList.contains('open');
      document.querySelectorAll('.drawer-section').forEach(s => s.classList.remove('open'));
      if (!isOpen) section.classList.add('open');
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  // Escape key closes drawer
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeDrawer();
  });
</script>
