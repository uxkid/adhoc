---
interface Props {
  currentPath?: string;
}
const { currentPath = '/' } = Astro.props;
---

<!-- ══ NAV ═══════════════════════════════════════════════════ -->
<header id="nav">
  <div class="nav-inner">

    <a href="/" class="nav-logo" aria-label="Adhoc — inicio">
      <img src="/logos/logo-primary.svg" alt="Adhoc" width="160" height="48" />
    </a>

    <nav class="nav-links" aria-label="Navegación principal">

      <!-- Soluciones (mega-dropdown) -->
      <div class="nav-item" id="ni-sol">
        <button class="nav-trigger" id="t-sol" aria-haspopup="true" aria-expanded="false">
          Soluciones
          <span class="chev-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4,6 8,10 12,6"/>
            </svg>
          </span>
        </button>

        <div class="dropdown" id="dd-sol" role="menu">
          <div class="dd-cols">

            <!-- Col 1 — Por industria -->
            <div class="dd-col">
              <div class="dd-col-label">Por industria</div>
              <a class="dd-item" href="#" role="menuitem" tabindex="-1">
                <div class="dd-icon" data-a="mus">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 3L1 8l9 5 9-5-9-5z"/><path d="M4 11v4c2 2 10 2 12 0v-4"/></svg>
                </div>
                <div class="dd-text">
                  <div class="dd-name">Educación</div>
                  <div class="dd-desc">Institutos, colegios y centros de formación</div>
                </div>
              </a>
              <a class="dd-item" href="#" role="menuitem" tabindex="-1">
                <div class="dd-icon" data-a="cor">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="16" height="13" rx="2"/><path d="M2 5l2-3h12l2 3"/><path d="M7 11h6"/></svg>
                </div>
                <div class="dd-text">
                  <div class="dd-name">Distribución y comercios</div>
                  <div class="dd-desc">Mayoristas, minoristas y distribuidoras B2B</div>
                </div>
              </a>
              <a class="dd-item" href="#" role="menuitem" tabindex="-1">
                <div class="dd-icon" data-a="vio">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2l-2 2 1 1-7 7-1-1-2 2 3 3 2-2-1-1 7-7 1 1 2-2-3-3z"/></svg>
                </div>
                <div class="dd-text">
                  <div class="dd-name">Servicios</div>
                  <div class="dd-desc">Consultoría, IT, agencias e ingeniería</div>
                </div>
              </a>
              <a class="dd-item" href="#" role="menuitem" tabindex="-1">
                <div class="dd-icon" data-a="lav">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="10" cy="10" r="2.5"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.2 4.2l1.4 1.4M14.4 14.4l1.4 1.4M4.2 15.8l1.4-1.4M14.4 5.6l1.4-1.4"/></svg>
                </div>
                <div class="dd-text">
                  <div class="dd-name">Manufactura</div>
                  <div class="dd-desc">Producción, insumos y cadena de valor</div>
                </div>
              </a>
            </div>

            <!-- Col 2 — Por tamaño -->
            <div class="dd-col">
              <div class="dd-col-label">Por tamaño</div>
              <a class="dd-item" href="#" role="menuitem" tabindex="-1">
                <div class="dd-icon" data-a="cor">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 17v-7"/><path d="M10 10c-3 0-5-2-5-5 3 0 5 2 5 5z"/><path d="M10 10c3 0 5-2 5-5-3 0-5 2-5 5z"/></svg>
                </div>
                <div class="dd-text">
                  <div class="dd-name">En crecimiento</div>
                  <div class="dd-desc">Hasta 50 personas</div>
                </div>
              </a>
              <a class="dd-item" href="#" role="menuitem" tabindex="-1">
                <div class="dd-icon" data-a="vio">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 17V4"/><path d="M5 9l5-5 5 5"/></svg>
                </div>
                <div class="dd-text">
                  <div class="dd-name">En escala</div>
                  <div class="dd-desc">50 a 200 personas</div>
                </div>
              </a>
              <a class="dd-item" href="#" role="menuitem" tabindex="-1">
                <div class="dd-icon" data-a="mus">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="14" height="15" rx="1"/><path d="M7 7h2M11 7h2M7 11h2M11 11h2M7 15h2M11 15h2"/></svg>
                </div>
                <div class="dd-text">
                  <div class="dd-name">Enterprise</div>
                  <div class="dd-desc">+200 personas o multi-empresa</div>
                </div>
              </a>
            </div>

            <!-- Col 3 — Featured card -->
            <div class="dd-col dd-featured-col">
              <a class="dd-featured-card" href="#" role="menuitem" tabindex="-1">
                <span class="dd-feat-pill">Caso de éxito</span>
                <div class="dd-feat-img" aria-hidden="true">
                  <span class="dd-feat-client">OneClick</span>
                </div>
                <div class="dd-feat-title">De planillas de Excel a operación centralizada en 3 meses</div>
                <div class="dd-feat-result">−40% tiempo administrativo · Ventas e inventario integrados</div>
                <div class="dd-feat-cta">Ver caso completo →</div>
              </a>
            </div>

          </div>

          <!-- Footer -->
          <div class="dd-footer">
            <div class="dd-footer-left">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="10,2 12.5,7.5 18.5,8 14,12.5 15.5,18.5 10,15.5 4.5,18.5 6,12.5 1.5,8 7.5,7.5"/></svg>
              <span class="dd-footer-text">
                <strong>Partner #1 de Odoo</strong> — conocé por qué.
                <a href="#" class="dd-footer-link">Ver historia →</a>
              </span>
            </div>
            <a href="#" class="dd-footer-link dd-footer-schedule">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="16" height="16" rx="2"/><path d="M6 1v4M14 1v4M2 8h16"/><circle cx="7" cy="12" r="1" fill="currentColor" stroke="none"/><circle cx="10" cy="12" r="1" fill="currentColor" stroke="none"/><circle cx="13" cy="12" r="1" fill="currentColor" stroke="none"/><circle cx="7" cy="15.5" r="1" fill="currentColor" stroke="none"/><circle cx="10" cy="15.5" r="1" fill="currentColor" stroke="none"/></svg>
              Agendar diagnóstico gratuito →
            </a>
          </div>
        </div>
      </div>

      <!-- Static links -->
      <a href="/pricing" class="nav-trigger">Precios</a>
      <a href="#" class="nav-trigger">Casos</a>
      <a href="#" class="nav-trigger">Recursos</a>

    </nav>

    <!-- CTAs -->
    <div class="nav-ctas">
      <button class="btn-ingresar">Ingresar</button>
      <button class="btn-demo" id="cta-nav">Solicitar demo</button>
      <button class="nav-hamburger" id="mobile-open" aria-label="Abrir menú" aria-expanded="false" aria-controls="mob-drawer">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="7" x2="19" y2="7"/>
          <line x1="3" y1="11" x2="19" y2="11"/>
          <line x1="3" y1="15" x2="19" y2="15"/>
        </svg>
      </button>
    </div>

  </div>
</header>

<!-- ══ MOBILE ════════════════════════════════════════════════ -->
<div class="mobile-overlay" id="mob-overlay" aria-hidden="true"></div>

<div class="mobile-drawer" id="mob-drawer" role="dialog" aria-modal="true" aria-label="Menú de navegación">
  <div class="drawer-handle" aria-hidden="true"></div>
  <button class="drawer-close" id="mob-close" aria-label="Cerrar menú">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
      <line x1="4" y1="4" x2="16" y2="16"/>
      <line x1="16" y1="4" x2="4" y2="16"/>
    </svg>
  </button>

  <!-- Soluciones accordion -->
  <div class="drawer-section" id="drs-sol">
    <button class="drawer-trigger" aria-expanded="false" aria-controls="drs-sol-body">
      Soluciones
      <span class="chev-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="4,6 8,10 12,6"/>
        </svg>
      </span>
    </button>
    <div class="drawer-content" id="drs-sol-body">
      <div class="drawer-group-label">Por industria</div>
      <a class="drawer-item" href="#">Educación</a>
      <a class="drawer-item" href="#">Distribución y comercios</a>
      <a class="drawer-item" href="#">Servicios</a>
      <a class="drawer-item" href="#">Manufactura</a>
      <div class="drawer-group-label" style="margin-top: 12px;">Por tamaño</div>
      <a class="drawer-item" href="#">En crecimiento — hasta 50 personas</a>
      <a class="drawer-item" href="#">En escala — 50 a 200 personas</a>
      <a class="drawer-item" href="#">Enterprise — +200 personas</a>
    </div>
  </div>

  <a class="drawer-link" href="/pricing">Precios</a>
  <a class="drawer-link" href="#">Casos</a>
  <a class="drawer-link" href="#">Recursos</a>

  <div class="drawer-ctas">
    <button class="btn-demo drawer-btn-full">Solicitar demo</button>
    <button class="btn-ingresar drawer-btn-full">Ingresar</button>
  </div>
</div>

<style is:global>
/* ─── NAV SHELL ─────────────────────────────────────────────── */
#nav {
  position: sticky;
  top: 0;
  z-index: 200;
  background: var(--color-canvas);
  border-bottom: 1px solid var(--border-medium);
  height: 64px;
}

.nav-inner {
  max-width: 1160px;
  margin: 0 auto;
  padding: 0 40px;
  height: 64px;
  display: flex;
  align-items: center;
  gap: 0;
}

/* ─── LOGO ────────────────────────────────────────────────── */
.nav-logo {
  display: flex;
  align-items: center;
  margin-right: 32px;
  flex-shrink: 0;
  text-decoration: none;
}

.nav-logo img {
  height: 48px;
  width: auto;
  display: block;
}

/* ─── NAV LINKS ───────────────────────────────────────────── */
.nav-links {
  display: flex;
  align-items: center;
  gap: 2px;
  flex: 1;
}

.nav-item {
  position: relative;
}

.nav-trigger {
  display: flex;
  align-items: center;
  gap: 4px;
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-ink);
  padding: 8px 14px;
  border-radius: 8px;
  background: transparent;
  border: none;
  cursor: pointer;
  transition: background 0.15s;
  white-space: nowrap;
  text-decoration: none;
  line-height: 1;
}

.nav-trigger:hover,
.nav-item.open > .nav-trigger {
  background: var(--color-canvas);
}

.chev-icon {
  display: inline-flex;
  align-items: center;
  opacity: 0.5;
  transition: transform 0.2s ease, opacity 0.2s;
  margin-left: 2px;
  flex-shrink: 0;
}

.nav-item.open .chev-icon {
  transform: rotate(180deg);
  opacity: 0.8;
}

/* ─── CTAs ────────────────────────────────────────────────── */
.nav-ctas {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-left: auto;
}

.btn-ingresar {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-ink);
  padding: 9px 20px;
  border-radius: var(--radius-button);
  background: transparent;
  border: 1.5px solid var(--color-ink);
  cursor: pointer;
  transition: background 0.15s;
  white-space: nowrap;
}

.btn-ingresar:hover {
  background: var(--color-canvas);
}

.btn-demo {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 500;
  color: #fff;
  padding: 9px 20px;
  border-radius: var(--radius-button);
  background: var(--color-primary);
  border: none;
  cursor: pointer;
  transition: background 0.15s;
  white-space: nowrap;
}

.btn-demo:hover {
  background: var(--color-primary-hover);
}

.nav-hamburger {
  display: none;
  align-items: center;
  justify-content: center;
  padding: 8px;
  background: none;
  border: none;
  cursor: pointer;
  border-radius: 8px;
  color: var(--color-ink);
}

.nav-hamburger:hover {
  background: var(--color-canvas);
}

/* ─── DROPDOWN ────────────────────────────────────────────── */
.dropdown {
  position: absolute;
  top: calc(100% + 8px);
  left: 0;
  background: var(--color-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  padding: 16px 20px 14px;
  min-width: 680px;
  opacity: 0;
  pointer-events: none;
  transform: translateY(-8px);
  transition: opacity 0.2s ease-out, transform 0.2s ease-out;
  z-index: 300;
}

/* Bridge hover gap between trigger and panel */
.dropdown::before {
  content: "";
  position: absolute;
  top: -10px;
  left: 0;
  right: 0;
  height: 10px;
}

.dropdown.open {
  opacity: 1;
  pointer-events: all;
  transform: translateY(0);
}

/* ─── DROPDOWN GRID ───────────────────────────────────────── */
.dd-cols {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 0;
}

.dd-col {
  padding: 0 4px;
}

.dd-col-label {
  font-family: var(--font-body);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #888;
  margin-bottom: 6px;
  padding: 4px 8px;
}

/* ─── DROPDOWN ITEMS ──────────────────────────────────────── */
.dd-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 7px 8px;
  border-radius: 8px;
  cursor: pointer;
  transition: background 0.1s;
  text-decoration: none;
  color: inherit;
}

.dd-item:hover {
  background: rgba(0, 0, 0, 0.05);
}

.dd-item:focus-visible {
  outline: 2px solid var(--color-primary);
  outline-offset: 2px;
  border-radius: 8px;
}

.dd-icon {
  width: 32px;
  height: 32px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  transition: transform 0.1s;
}

.dd-item:hover .dd-icon {
  transform: scale(1.08);
}

/* Icon accent fills — used only as icon container backgrounds */
.dd-icon[data-a="cor"]          { background: #FFE5DE; }
.dd-icon[data-a="cor"] svg      { stroke: #FF7348; }
.dd-icon[data-a="vio"]          { background: #EAE7FA; }
.dd-icon[data-a="vio"] svg      { stroke: #7C6CD8; }
.dd-icon[data-a="mus"]          { background: #FFF3D0; }
.dd-icon[data-a="mus"] svg      { stroke: #B87800; }
.dd-icon[data-a="lav"]          { background: #F0EDFB; }
.dd-icon[data-a="lav"] svg      { stroke: #9A8FDE; }

.dd-item:hover .dd-icon[data-a="cor"] { background: #FFD5C8; }
.dd-item:hover .dd-icon[data-a="vio"] { background: #DDD9F7; }
.dd-item:hover .dd-icon[data-a="mus"] { background: #FFEAB8; }
.dd-item:hover .dd-icon[data-a="lav"] { background: #E4DFF8; }

.dd-name {
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-ink);
  line-height: 1.3;
  margin-bottom: 1px;
}

.dd-desc {
  font-family: var(--font-body);
  font-size: 0.78rem;
  color: #888;
  line-height: 1.35;
}

/* ─── FEATURED COL ────────────────────────────────────────── */
.dd-featured-col {
  padding-left: 16px;
  border-left: 1px solid var(--border-subtle);
}

.dd-featured-card {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 18px;
  background: var(--color-lavender);
  border: none;
  border-radius: 20px;
  text-decoration: none;
  color: inherit;
  transition: transform 0.15s ease;
  cursor: pointer;
  height: 100%;
}

.dd-featured-card:hover {
  transform: translateY(-2px);
}

.dd-feat-pill {
  display: inline-flex;
  align-items: center;
  background: var(--color-lavender-fill);
  color: var(--color-lavender);
  font-family: var(--font-body);
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: var(--radius-tag);
  align-self: flex-start;
}

.dd-feat-img {
  background: var(--color-primary);
  border-radius: 12px;
  height: 96px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.dd-feat-client {
  font-family: var(--font-display);
  font-weight: 500;
  font-size: 1.3rem;
  color: #fff;
  letter-spacing: -0.01em;
}

.dd-feat-title {
  font-family: var(--font-display);
  font-weight: 500;
  font-size: 1rem;
  line-height: 1.3;
  color: var(--color-ink);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.dd-feat-result {
  font-family: var(--font-body);
  font-size: 0.8rem;
  color: var(--color-text-secondary);
  line-height: 1.45;
}

.dd-feat-cta {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--color-primary);
  margin-top: auto;
}

.dd-featured-card:hover .dd-feat-cta {
  text-decoration: underline;
}

/* ─── DROPDOWN FOOTER ─────────────────────────────────────── */
.dd-footer {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--border-subtle);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}

.dd-footer-left {
  display: flex;
  align-items: center;
  gap: 8px;
}

.dd-footer-text {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  color: var(--color-text-secondary);
}

.dd-footer-text strong {
  color: var(--color-ink);
  font-weight: 600;
}

.dd-footer-link {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--color-ink);
  text-decoration: none;
  transition: text-decoration 0.12s;
}

.dd-footer-link:hover {
  text-decoration: underline;
}

.dd-footer-schedule {
  display: flex;
  align-items: center;
  gap: 6px;
}

/* ─── MOBILE OVERLAY ─────────────────────────────────────── */
.mobile-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.3);
  z-index: 400;
  opacity: 0;
  transition: opacity 0.2s;
}

.mobile-overlay.open {
  display: block;
  opacity: 1;
}

/* ─── MOBILE DRAWER ──────────────────────────────────────── */
.mobile-drawer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 500;
  background: var(--color-canvas);
  border-radius: 20px 20px 0 0;
  padding: 20px 0 40px;
  max-height: 85vh;
  overflow-y: auto;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
}

.mobile-drawer.open {
  transform: translateY(0);
}

.drawer-handle {
  width: 36px;
  height: 4px;
  border-radius: 2px;
  background: var(--border-medium);
  margin: 0 auto 20px;
}

.drawer-close {
  position: absolute;
  top: 16px;
  right: 20px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  color: #888;
  display: flex;
  align-items: center;
}

.drawer-section {
  border-bottom: 1px solid var(--border-subtle);
}

.drawer-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 16px 24px;
  font-family: var(--font-body);
  font-size: 1rem;
  font-weight: 500;
  color: var(--color-ink);
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
}

.drawer-content {
  display: none;
  padding: 0 24px 16px;
  flex-direction: column;
}

.drawer-section.open .drawer-content {
  display: flex;
}

.drawer-section.open .drawer-trigger .chev-icon {
  transform: rotate(180deg);
  opacity: 0.8;
}

.drawer-group-label {
  font-family: var(--font-body);
  font-size: 0.65rem;
