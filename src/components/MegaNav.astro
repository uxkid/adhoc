  padding: 14px;
}

/* ─── RESPONSIVE ─────────────────────────────────────────── */
@media (max-width: 767px) {
  .nav-links,
  .btn-ingresar {
    display: none;
  }

  .nav-hamburger {
    display: flex;
  }
