</style>

<script>
// ── DROPDOWN ──────────────────────────────────────────────────
const solItem    = document.getElementById('ni-sol')!;
const solTrigger = document.getElementById('t-sol')!;
const solDD      = document.getElementById('dd-sol')!;

let openTimer: ReturnType<typeof setTimeout> | null = null;
let closeTimer: ReturnType<typeof setTimeout> | null = null;

function openDD() {
  if (openTimer) clearTimeout(openTimer);
  if (closeTimer) clearTimeout(closeTimer);
  solDD.classList.add('open');
  solTrigger.setAttribute('aria-expanded', 'true');
  solItem.classList.add('open');
  solDD.querySelectorAll<HTMLElement>('[role="menuitem"]')
    .forEach(el => el.setAttribute('tabindex', '0'));
}

function closeDD(immediate = false) {
  if (closeTimer) clearTimeout(closeTimer);
  const doClose = () => {
    solDD.classList.remove('open');
    solTrigger.setAttribute('aria-expanded', 'false');
    solItem.classList.remove('open');
    solDD.querySelectorAll<HTMLElement>('[role="menuitem"]')
      .forEach(el => el.setAttribute('tabindex', '-1'));
  };
  if (immediate) doClose();
  else closeTimer = setTimeout(doClose, 150);
}

// Hover
solTrigger.addEventListener('mouseenter', () => {
  if (closeTimer) clearTimeout(closeTimer);
  openTimer = setTimeout(openDD, 100);
});
solTrigger.addEventListener('mouseleave', () => {
  if (openTimer) clearTimeout(openTimer);
  closeDD();
});
solDD.addEventListener('mouseenter', () => {
  if (closeTimer) clearTimeout(closeTimer);
});
solDD.addEventListener('mouseleave', () => closeDD());

// Keyboard
solTrigger.addEventListener('keydown', e => {
  if (e.key === 'Enter' || e.key === ' ') {
    e.preventDefault();
    solDD.classList.contains('open') ? closeDD(true) : openDD();
  }
  if (e.key === 'Escape') { closeDD(true); solTrigger.focus(); }
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    openDD();
    const first = solDD.querySelector<HTMLElement>('[role="menuitem"]');
    first?.focus();
  }
});

solDD.addEventListener('keydown', e => {
  const items = [...solDD.querySelectorAll<HTMLElement>('[role="menuitem"]')];
  const idx   = items.indexOf(document.activeElement as HTMLElement);
  if (e.key === 'ArrowDown')  { e.preventDefault(); items[(idx + 1) % items.length]?.focus(); }
  if (e.key === 'ArrowUp')    { e.preventDefault(); items[(idx - 1 + items.length) % items.length]?.focus(); }
  if (e.key === 'Escape')     { closeDD(true); solTrigger.focus(); }
});

// Outside click
document.addEventListener('click', e => {
  if (!solItem.contains(e.target as Node)) closeDD(true);
});

// ── MOBILE DRAWER ─────────────────────────────────────────────
const overlay   = document.getElementById('mob-overlay')!;
const drawer    = document.getElementById('mob-drawer')!;
const openBtn   = document.getElementById('mobile-open')!;
const closeBtn  = document.getElementById('mob-close')!;

function openDrawer() {
  overlay.classList.add('open');
  overlay.removeAttribute('aria-hidden');
  drawer.classList.add('open');
  openBtn.setAttribute('aria-expanded', 'true');
  document.body.style.overflow = 'hidden';
}

function closeDrawer() {
  overlay.classList.remove('open');
  overlay.setAttribute('aria-hidden', 'true');
  drawer.classList.remove('open');
  openBtn.setAttribute('aria-expanded', 'false');
  document.body.style.overflow = '';
}

openBtn.addEventListener('click', openDrawer);
closeBtn.addEventListener('click', closeDrawer);
overlay.addEventListener('click', closeDrawer);
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDrawer(); });

// Accordion
const drawerSection = document.getElementById('drs-sol')!;
const drawerTrigger = drawerSection.querySelector<HTMLButtonElement>('.drawer-trigger')!;
drawerTrigger.addEventListener('click', () => {
  const isOpen = drawerSection.classList.contains('open');
  drawerSection.classList.toggle('open', !isOpen);
  drawerTrigger.setAttribute('aria-expanded', String(!isOpen));
});
</script>
