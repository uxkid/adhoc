---
interface Props {
  variant?: 'lav' | 'vio' | 'cor' | 'mus' | 'dark' | 'canvas' | 'out-vio';
  size?: 'sm' | 'md' | 'lg';
  label: string;
}

const { variant = 'lav', size = 'md', label } = Astro.props;
---

<span class:list={['tag', `tag--${variant}`, `tag--${size}`]}>
  {label}
</span>

<style>
  .tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-weight: 500;
    border-radius: var(--radius-tag);
    letter-spacing: 0.02em;
    line-height: 1;
    white-space: nowrap;
    border: 1.5px solid transparent;
  }

  /* ─── Sizes ─── */
  .tag--sm { padding: 3px 10px;  font-size: 0.65rem; }
  .tag--md { padding: 5px 14px;  font-size: 0.75rem; }
  .tag--lg { padding: 7px 18px;  font-size: 0.875rem; }

  /* ─── Variants ─── */

  /* lav: #EDE9FB / #000 = 17.65:1 AAA */
  .tag--lav {
    background: var(--color-lavender-fill);
    color: var(--color-ink);
  }

  /* vio: #7C6CD8 / #000 = 4.99:1 AA — única excepción AA del sistema, ver CLAUDE.md */
  .tag--vio {
    background: var(--color-primary);
    color: var(--color-ink);
  }

  /* cor: #FF7348 / #000 = 7.79:1 AAA */
  .tag--cor {
    background: var(--color-coral);
    color: var(--color-ink);
  }

  /* mus: #FEA912 / #000 = 10.91:1 AAA */
  .tag--mus {
    background: var(--color-mustard);
    color: var(--color-ink);
  }

  /* dark: #000 / #fff = 21:1 AAA */
  .tag--dark {
    background: var(--color-ink);
    color: var(--color-surface);
  }

  /* canvas: #E9E5DF / #000 = 16.74:1 AAA */
  .tag--canvas {
    background: var(--color-canvas);
    color: var(--color-ink);
  }

  /* out-vio: texto #000 = 21:1 AAA; borde primario = 4.21:1 en blanco / 3.35:1 en canvas — pasa WCAG 1.4.11 */
  .tag--out-vio {
    background: transparent;
    color: var(--color-ink);
    border-color: var(--color-primary);
  }
</style>
