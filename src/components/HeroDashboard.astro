---
// Componente decorativo — sin props, sin JS
---

<div class="hero-visual" aria-hidden="true">
  <div class="dashboard">

    <!-- Barra macOS: dots + tabs -->
    <div class="db-bar">
      <div class="db-dots">
        <span class="db-dot db-dot--red"></span>
        <span class="db-dot db-dot--yellow"></span>
        <span class="db-dot db-dot--green"></span>
      </div>
      <div class="db-tabs">
        <span class="db-tab db-tab--active">Tablero</span>
        <span class="db-tab">Ventas</span>
        <span class="db-tab">Inventario</span>
        <span class="db-tab">Finanzas</span>
        <span class="db-tab">Proyectos</span>
      </div>
    </div>

    <!-- Grid: sidebar + contenido -->
    <div class="db-grid">

      <div class="db-sidebar">
        <div class="db-nav-item db-nav-item--active">
          <span class="db-nav-dot" style="background: var(--color-primary)"></span>
          Tablero
        </div>
        <div class="db-nav-item">
          <span class="db-nav-dot" style="background: var(--color-coral)"></span>
          CRM
        </div>
        <div class="db-nav-item">
          <span class="db-nav-dot" style="background: var(--color-mustard)"></span>
          Ventas
        </div>
        <div class="db-nav-item">
          <span class="db-nav-dot" style="background: var(--color-lavender)"></span>
          Inventario
        </div>
        <div class="db-nav-item">
          <span class="db-nav-dot" style="background: #3BB56A"></span>
          Facturación
        </div>
        <div class="db-nav-item">
          <span class="db-nav-dot" style="background: #888"></span>
          Proyectos
        </div>
        <div class="db-nav-item">
          <span class="db-nav-dot" style="background: #888"></span>
          Empleados
        </div>
        <div class="db-nav-item">
          <span class="db-nav-dot" style="background: #888"></span>
          Soporte
        </div>
      </div>

      <div class="db-main">

        <div class="db-kpis">
          <div class="db-kpi">
            <div class="db-kpi-lbl">Ventas del mes</div>
            <div class="db-kpi-val">$4.2M</div>
            <div class="db-kpi-delta db-kpi-delta--up">↑ 18%</div>
          </div>
          <div class="db-kpi">
            <div class="db-kpi-lbl">Pedidos activos</div>
            <div class="db-kpi-val">318</div>
            <div class="db-kpi-delta db-kpi-delta--up">↑ 12%</div>
          </div>
          <div class="db-kpi">
            <div class="db-kpi-lbl">Stock disponible</div>
            <div class="db-kpi-val">97%</div>
            <div class="db-kpi-delta db-kpi-delta--dn">↓ 2%</div>
          </div>
          <div class="db-kpi">
            <div class="db-kpi-lbl">Clientes activos</div>
            <div class="db-kpi-val">1,204</div>
            <div class="db-kpi-delta db-kpi-delta--up">↑ 7%</div>
          </div>
        </div>

        <div class="db-charts">
          <div class="db-chart-box">
            <div class="db-chart-ttl">Facturación — últimas 8 semanas</div>
            <div class="db-bars">
              <span class="db-bar" style="height: 38%; background: var(--color-lavender)"></span>
              <span class="db-bar" style="height: 55%; background: var(--color-lavender)"></span>
              <span class="db-bar" style="height: 48%; background: var(--color-lavender)"></span>
              <span class="db-bar" style="height: 72%; background: var(--color-primary)"></span>
              <span class="db-bar" style="height: 62%; background: var(--color-lavender)"></span>
              <span class="db-bar" style="height: 85%; background: var(--color-primary)"></span>
              <span class="db-bar" style="height: 78%; background: var(--color-lavender)"></span>
              <span class="db-bar" style="height: 100%; background: var(--color-coral)"></span>
            </div>
          </div>
          <div class="db-chart-box">
            <div class="db-chart-ttl">Top clientes</div>
            <div class="db-list">
              <div class="db-list-item">
                <span>RE/MAX</span>
                <span class="db-badge" style="background: var(--color-lavender); color: var(--color-ink)">$820k</span>
              </div>
              <div class="db-list-item">
                <span>Arbusta</span>
                <span class="db-badge" style="background: var(--color-canvas); color: var(--color-ink)">$540k</span>
              </div>
              <div class="db-list-item">
                <span>OneClick</span>
                <span class="db-badge" style="background: var(--color-canvas); color: var(--color-ink)">$390k</span>
              </div>
              <div class="db-list-item">
                <span>PayPal AR</span>
                <span class="db-badge" style="background: var(--color-canvas); color: var(--color-ink)">$280k</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<style>
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .dashboard {
    background: var(--color-surface);
    border: 1px solid var(--border-subtle);
    border-bottom: none;
    border-radius: 16px 16px 0 0;
    width: min(960px, 92%);
    overflow: hidden;
    padding: 20px 20px 0;
  }

  /* ── Barra macOS ── */
  .db-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border-medium);
  }

  .db-dots { display: flex; gap: 5px; }

  .db-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .db-dot--red    { background: #FF6058; }
  .db-dot--yellow { background: #FFBC2E; }
  .db-dot--green  { background: #28C840; }

  .db-tabs {
    display: flex;
    gap: 4px;
    margin-left: 12px;
  }

  .db-tab {
    font-size: 0.68rem;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 999px;
    color: #888;
    cursor: default;
  }
  .db-tab--active {
    background: var(--color-primary);
    color: var(--color-surface);
  }

  /* ── Grid ── */
  .db-grid {
    display: grid;
    grid-template-columns: 200px 1fr;
  }

  /* ── Sidebar ── */
  .db-sidebar {
    border-right: 1px solid var(--border-medium);
    padding: 0 16px 24px 0;
  }

  .db-nav-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 10px;
    border-radius: 8px;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    margin-bottom: 2px;
  }
  .db-nav-item--active {
    background: var(--color-lavender);
    color: var(--color-ink);
  }

  .db-nav-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Contenido principal ── */
  .db-main { padding: 0 0 0 20px; }

  .db-kpis {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-bottom: 16px;
  }

  .db-kpi {
    background: var(--color-canvas);
    border-radius: 10px;
    padding: 12px;
  }

  .db-kpi-lbl {
    font-size: 0.65rem;
    font-weight: 500;
    color: #888;
    margin-bottom: 4px;
  }

  .db-kpi-val {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.4rem;
    line-height: 1;
  }

  .db-kpi-delta {
    font-size: 0.65rem;
    font-weight: 500;
    margin-top: 3px;
  }
  .db-kpi-delta--up { color: #3BB56A; }
  .db-kpi-delta--dn { color: var(--color-coral); }

  /* ── Gráficos ── */
  .db-charts {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 10px;
  }

  .db-chart-box {
    background: var(--color-canvas);
    border-radius: 10px;
    padding: 12px;
  }

  .db-chart-ttl {
    font-size: 0.68rem;
    font-weight: 600;
    margin-bottom: 10px;
    color: var(--color-text-secondary);
  }

  .db-bars {
    display: flex;
    align-items: flex-end;
    gap: 5px;
    height: 56px;
  }

  .db-bar {
    flex: 1;
    border-radius: 3px 3px 0 0;
  }

  /* ── Lista ── */
  .db-list-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 7px 0;
    border-bottom: 1px solid var(--border-medium);
    font-size: 0.7rem;
  }
  .db-list-item:last-child { border: none; }

  .db-badge {
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.62rem;
    font-weight: 600;
  }
</style>
